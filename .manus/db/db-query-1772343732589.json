{
  "query": "SELECT DISTINCT o.id, o.orderNumber, o.erpCompanyId,\n  COUNT(DISTINCT oi.id) as itemCount,\n  SUM(CASE WHEN (p.imageUrl IS NOT NULL AND p.imageUrl != '') THEN 1 ELSE 0 END) as itemsWithImage,\n  SUM(CASE WHEN pv.supplierId IS NOT NULL THEN 1 ELSE 0 END) as itemsWithSupplier\nFROM orders o\nJOIN order_items oi ON oi.orderId = o.id\nJOIN products p ON p.id = oi.productId\nLEFT JOIN product_variants pv ON pv.id = oi.variantId\nGROUP BY o.id, o.orderNumber, o.erpCompanyId\nORDER BY o.id DESC\nLIMIT 15;",
