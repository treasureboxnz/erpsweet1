import React, { useState, useEffect } from "react";
import { trpc } from "@/lib/trpc";
import { Button } from "@/components/ui/button";
import { Label } from "@/components/ui/label";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import { Card } from "@/components/ui/card";
import {
  Dialog,
  DialogContent,
  DialogHeader,
  DialogTitle,
  DialogTrigger,
} from "@/components/ui/dialog";
import { ChevronUp, ChevronDown, Trash2, Plus, Pencil, Search } from "lucide-react";
import { toast } from "sonner";
import { ColorIcon } from "@/components/ColorIcon";

interface Material {
  id?: number;
  materialType: string | null;
  materialColorId: number;
  sortOrder: number;
  createdAt?: Date;
  // 用于显示的额外信息（后端API返回的完整数据）
  color?: {
    id: number;
    erpCompanyId: number | null;
    boardId: number;
    colorCode: string;
    colorName: string | null;
    fullCode: string | null;
    hexColor: string | null;
    imageUrl: string | null;
    thumbnailUrl: string | null;
    stockQuantity: number | null;
    notes: string | null;
    status: string;
    sortOrder: number;
    createdAt: Date;
    updatedAt: Date;
  } | null;
  supplier?: {
    id: number;
    erpCompanyId: number | null;
    categoryId: number | null;
    code: string;
    name: string;
    contactPerson: string | null;
    contactPhone: string | null;
    contactEmail: string | null;
    address: string | null;
    notes: string | null;
    status: string;
    createdAt: Date;
    updatedAt: Date;
  } | null;
  board?: {
    id: number;
    erpCompanyId: number | null;
    supplierId: number;
    categoryId: number | null;
    boardNumber: string;
    boardName: string | null;
    materialType: string | null;
    pricePerMeter: string;
    currency: string;
    minOrderQuantity: number | null;
    leadTime: number | null;
    description: string | null;
    notes: string | null;
    imageUrl: string | null;
    status: string;
    createdAt: Date;
    updatedAt: Date;
  } | null;
}

interface VariantMaterialsManagerProps {
  variantId: number;
  onChange?: (materials: Material[]) => void;
}

export function VariantMaterialsManager({
  variantId,
  onChange,
}: VariantMaterialsManagerProps) {
  const [materials, setMaterials] = useState<Material[]>([]);
  const [isAddingMaterial, setIsAddingMaterial] = useState(false);
  const [editingMaterialId, setEditingMaterialId] = useState<number | null>(null);
  const [newMaterialType, setNewMaterialType] = useState("fabric");
  const [newMaterialColorId, setNewMaterialColorId] = useState<number | null>(null);
  const [colorSearchQuery, setColorSearchQuery] = useState("");

  // 查询材料类型列表（动态加载）
  const { data: materialTypesData } = trpc.materialTypes.list.useQuery();

  // 查询批次的材料列表
  const { data: materialsData, refetch: refetchMaterials } =
    trpc.variantMaterials.list.useQuery({ variantId });

  // 查询材料颜色（用于搜索，按材料类型筛选）
  const { data: colorsData } = trpc.materials.colors.list.useQuery(
    { 
      search: colorSearchQuery 
    },
    { enabled: colorSearchQuery.length > 0 }
  );

  // 添加材料
  const addMaterialMutation = trpc.variantMaterials.add.useMutation({
    onSuccess: () => {
      toast.success("材料添加成功");
      refetchMaterials();
      setIsAddingMaterial(false);
      setNewMaterialColorId(null);
      setColorSearchQuery("");
    },
    onError: (error) => {
      toast.error(`添加失败：${error.message}`);
    },
  });

  // 更新材料
  const updateMaterialMutation = trpc.variantMaterials.update.useMutation({
    onSuccess: () => {
      toast.success("材料更新成功");
      refetchMaterials();
      setEditingMaterialId(null);
      setNewMaterialColorId(null);
      setColorSearchQuery("");
    },
    onError: (error) => {
      toast.error(`更新失败：${error.message}`);
    },
  });

  // 删除材料
  const deleteMaterialMutation = trpc.variantMaterials.delete.useMutation({
    onSuccess: () => {
      toast.success("材料删除成功");
      refetchMaterials();
    },
    onError: (error) => {
      toast.error(`删除失败：${error.message}`);
    },
  });

  // 调整材料顺序
  const reorderMutation = trpc.variantMaterials.reorder.useMutation({
    onSuccess: () => {
      refetchMaterials();
    },
    onError: (error: any) => {
      toast.error(`排序失败：${error.message}`);
    },
  });

  // 同步材料数据
  useEffect(() => {
    if (materialsData) {
      setMaterials(materialsData);
      onChange?.(materialsData);
    }
  }, [materialsData, onChange]);

  // 处理编辑材料
  const handleEditMaterial = (material: Material) => {
    setEditingMaterialId(material.id!);
    setNewMaterialType(material.materialType || "fabric");
    setNewMaterialColorId(material.materialColorId);
    // 设置搜索框显示当前材料的完整信息
    if (material.color && material.supplier && material.board) {
      setColorSearchQuery(
        `${material.supplier.code} - ${material.board.boardNumber} - ${material.color.colorCode}`
      );
    }
  };

  // 取消编辑
  const handleCancelEdit = () => {
    setEditingMaterialId(null);
    setNewMaterialColorId(null);
    setColorSearchQuery("");
  };

  // 保存编辑
  const handleSaveEdit = () => {
    if (!editingMaterialId || !newMaterialColorId) return;

    updateMaterialMutation.mutate({
      id: editingMaterialId,
      materialType: newMaterialType,
      materialColorId: newMaterialColorId,
    });
  };

  // 添加材料
  const handleAddMaterial = () => {
    if (!newMaterialColorId) return;

    addMaterialMutation.mutate({
      variantId,
      materialType: newMaterialType,
      materialColorId: newMaterialColorId,
    });
  };

  // 删除材料
  const handleDeleteMaterial = (materialId: number) => {
    if (!confirm("确定要删除这个材料吗？")) return;
    deleteMaterialMutation.mutate({ id: materialId });
  };

  // 上移材料
  const handleMoveUp = (materialId: number, index: number) => {
    if (index === 0) return;
    reorderMutation.mutate({
      id: materialId,
      direction: "up",
    });
  };

  // 下移材料
  const handleMoveDown = (materialId: number, index: number) => {
    if (index === materials.length - 1) return;
    reorderMutation.mutate({
      id: materialId,
      direction: "down",
    });
  };

  return (
    <div className="space-y-4">
      <div className="flex items-center justify-between">
        <h3 className="text-lg font-semibold">批次材料清单</h3>
        <Dialog open={isAddingMaterial} onOpenChange={setIsAddingMaterial}>
          <DialogTrigger asChild>
            <Button
              type="button"
              variant="outline"
              size="sm"
            >
              <Plus className="w-4 h-4 mr-1" />
              添加更多材料
            </Button>
          </DialogTrigger>
          <DialogContent className="!w-[600px] !h-[900px] !max-w-[600px] max-h-[95vh] overflow-y-auto">
            <DialogHeader>
              <DialogTitle>添加新材料</DialogTitle>
            </DialogHeader>

      {/* 材料列表 */}
      <div className="space-y-3">
        {materials.map((material, index) => (
          <Card key={material.id} className="p-4">
            <div className="flex items-center gap-4">
              {/* 材料图片 */}
              <ColorIcon
                imageUrl={material.color?.imageUrl || null}
                colorCode={material.color?.colorCode || ""}
                colorName={material.color?.colorName || ""}
                size="lg"
              />

              {/* 材料信息 */}
              <div className="flex-1 min-w-0">
                <div className="flex items-center gap-2 mb-1">
                  {index === 0 && (
                    <span className="text-yellow-600 text-sm font-medium">
                      ⭐ 主材料
                    </span>
                  )}
                  <span className="text-sm text-gray-600">
                    {material.materialType || "布料"}
                  </span>
                </div>
                <div className="text-sm font-medium truncate">
                  {material.supplier?.code} - {material.board?.boardNumber} -{" "}
                  {material.color?.colorCode} · {material.color?.colorName}
                </div>
              </div>

              {/* 操作按钮 */}
              <div className="flex items-center gap-1">
                <Button
                  type="button"
                  variant="ghost"
                  size="sm"
                  onClick={() => handleEditMaterial(material)}
                  title="编辑材料"
                >
                  <Pencil className="w-4 h-4" />
                </Button>
                <Button
                  type="button"
                  variant="ghost"
                  size="sm"
                  onClick={() => handleMoveUp(material.id!, index)}
                  disabled={index === 0}
                  title="上移"
                >
                  <ChevronUp className="w-4 h-4" />
                </Button>
                <Button
                  type="button"
                  variant="ghost"
                  size="sm"
                  onClick={() => handleMoveDown(material.id!, index)}
                  disabled={index === materials.length - 1}
                  title="下移"
                >
                  <ChevronDown className="w-4 h-4" />
                </Button>
                <Button
                  type="button"
                  variant="ghost"
                  size="sm"
                  onClick={() => handleDeleteMaterial(material.id!)}
                  disabled={index === 0}
                  title={index === 0 ? "主材料不可删除" : "删除材料"}
                >
                  <Trash2 className="w-4 h-4" />
                </Button>
              </div>
            </div>
          </Card>
        ))}

        {materials.length === 0 && (
          <div className="text-center py-8 text-gray-500 text-sm">
            暂无材料，请点击"添加更多材料"按钮添加
          </div>
        )}
      </div>

      {/* 编辑材料对话框 */}
      {editingMaterialId && (
        <Card className="p-4 border-2 border-primary/20">
          <div className="space-y-4">
            <div className="flex items-center justify-between">
              <Label className="text-base font-semibold">编辑材料</Label>
              <Button
                type="button"
                variant="ghost"
                size="sm"
                onClick={handleCancelEdit}
              >
                取消
              </Button>
            </div>

            {/* 材料类型选择 */}
            <div>
              <Label>材料类型</Label>
              <Select
                value={newMaterialType}
                onValueChange={(value) => {
                  setNewMaterialType(value);
                  // 切换材料类型时清除当前选择的材料颜色
                  setNewMaterialColorId(null);
                  setColorSearchQuery("");
                }}
              >
                <SelectTrigger>
                  <SelectValue />
                </SelectTrigger>
                <SelectContent>
                  {materialTypesData?.map((type) => (
                    <SelectItem key={type.id} value={type.name}>
                      {type.icon} {type.name}
                    </SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>

            {/* 材料颜色选择 */}
            <div>
              <Label>材料颜色</Label>
              <div className="relative">
                <input
                  type="text"
                  placeholder="搜索供应商、布板或颜色编号..."
                  value={colorSearchQuery}
                  onChange={(e) => setColorSearchQuery(e.target.value)}
                  className="w-full px-3 py-2 pr-10 border rounded-md"
                />
                {colorSearchQuery && (
                  <button
                    type="button"
                    onClick={() => {
                      setColorSearchQuery("");
                      setNewMaterialColorId(null);
                    }}
                    className="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600"
                  >
                    ✕
                  </button>
                )}
              </div>
              {colorSearchQuery && colorsData && colorsData.length > 0 && (
                <div className="mt-2 max-h-48 overflow-y-auto border rounded-md">
                  {colorsData.map((item: any) => (
                    <div
                      key={item.color.id}
                      className="flex items-center gap-3 p-2 hover:bg-gray-50 cursor-pointer"
                      onClick={() => {
                        setNewMaterialColorId(item.color.id);
                        setColorSearchQuery(
                          `${item.supplier.code} - ${item.board.boardNumber} - ${item.color.colorCode}`
                        );
                      }}
                    >
                      <ColorIcon
                        imageUrl={item.color.imageUrl}
                        colorCode={item.color.colorCode}
                        colorName={item.color.colorName}
                        size="sm"
                      />
                      <span className="text-sm">
                        {item.supplier.code} - {item.board.boardNumber} -{" "}
                        {item.color.colorCode}
                      </span>
                    </div>
                  ))}
                </div>
              )}
            </div>

            <Button
              type="button"
              onClick={handleSaveEdit}
              disabled={!newMaterialColorId || updateMaterialMutation.isPending}
              className="w-full"
            >
              {updateMaterialMutation.isPending ? "保存中..." : "保存"}
            </Button>
          </div>
        </Card>
      )}

            <div className="space-y-4">

            {/* 材料类型选择 */}
            <div>
              <Label>材料类型</Label>
              <Select
                value={newMaterialType}
                onValueChange={(value) => {
                  setNewMaterialType(value);
                  // 切换材料类型时清除当前选择的材料颜色
                  setNewMaterialColorId(null);
                  setColorSearchQuery("");
                }}
              >
                <SelectTrigger>
                  <SelectValue />
                </SelectTrigger>
                <SelectContent>
                  {materialTypesData?.map((type) => (
                    <SelectItem key={type.id} value={type.name}>
                      {type.icon} {type.name}
                    </SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>

            {/* 材料颜色选择 */}
            <div>
              <Label>材料颜色</Label>
              <div className="relative">
                <input
                  type="text"
                  placeholder="搜索供应商、布板或颜色编号..."
                  value={colorSearchQuery}
                  onChange={(e) => setColorSearchQuery(e.target.value)}
                  className="w-full px-3 py-2 pr-10 border rounded-md"
                />
                {colorSearchQuery && (
                  <button
                    type="button"
                    onClick={() => {
                      setColorSearchQuery("");
                      setNewMaterialColorId(null);
                    }}
                    className="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600"
                  >
                    ✕
                  </button>
                )}
              </div>
              {colorSearchQuery && colorsData && colorsData.length > 0 && (
                <div className="mt-2 max-h-48 overflow-y-auto border rounded-md">
                  {colorsData.map((item: any) => (
                    <div
                      key={item.color.id}
                      className="flex items-center gap-3 p-2 hover:bg-gray-50 cursor-pointer"
                      onClick={() => {
                        setNewMaterialColorId(item.color.id);
                        setColorSearchQuery(
                          `${item.supplier.code} - ${item.board.boardNumber} - ${item.color.colorCode}`
                        );
                      }}
                    >
                      <ColorIcon
                        imageUrl={item.color.imageUrl}
                        colorCode={item.color.colorCode}
                        colorName={item.color.colorName}
                        size="sm"
                      />
                      <span className="text-sm">
                        {item.supplier.code} - {item.board.boardNumber} -{" "}
                        {item.color.colorCode}
                      </span>
                    </div>
                  ))}
                </div>
              )}
            </div>

            <Button
              type="button"
              onClick={() => {
                handleAddMaterial();
                setIsAddingMaterial(false);
              }}
              disabled={!newMaterialColorId || addMaterialMutation.isPending}
              className="w-full"
            >
              {addMaterialMutation.isPending ? "添加中..." : "添加"}
            </Button>
          </div>
          </DialogContent>
        </Dialog>
      </div>

      {/* 提示信息 */}
      <div className="text-xs text-gray-500 space-y-1">
        <p>💡 提示：</p>
        <p>• 主材料（带⭐标记）不可删除，但可以修改类型和颜色</p>
        <p>• 使用上移/下移按钮调整材料顺序，排在最前的材料将显示在订单中</p>
        <p>• 订单中最多显示前3个材料图片</p>
      </div>
    </div>
  );
}
